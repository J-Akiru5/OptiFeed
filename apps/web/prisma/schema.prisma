// TODO(karl): Confirm indexes, cascading deletes, and row-level security policies once the access model is finalized.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pond {
  id              String   @id @default(cuid())
  ownerId         String
  name            String
  feedingRatePct  Float
  feedsPerDay     Int
  scheduleStart   DateTime @db.Time()
  scheduleEnd     DateTime @db.Time()
  createdAt       DateTime @default(now())

  devices        Device[]
  biomassLogs    BiomassLog[]
  fcrReports     FcrReport[]
  notifications  Notification[]
  energyDevices  EnergyDevice[]
}

model Device {
  id             String    @id @default(cuid())
  pondId         String
  name           String
  connectivity   String
  isPaused       Boolean   @default(false)
  lastSyncedAt   DateTime?
  hopperLevelPct Float

  pond          Pond           @relation(fields: [pondId], references: [id])
  feedingEvents FeedingEvent[]
}

model BiomassLog {
  id              String   @id @default(cuid())
  pondId          String
  sampleWeightKg  Float
  sampleLengthCm  Float
  sampleCount     Int
  avgWeightKg     Float
  recordedAt      DateTime @default(now())

  pond Pond @relation(fields: [pondId], references: [id])
}

model FeedingEvent {
  id                String   @id @default(cuid())
  deviceId          String
  scheduledTime     DateTime
  dispensedVolumeG  Float
  status            String
  createdAt         DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])
}

model FcrReport {
  id            String   @id @default(cuid())
  pondId        String
  periodStart   DateTime
  periodEnd     DateTime
  totalFeedKg   Float
  biomassGainKg Float
  fcrValue      Float

  pond Pond @relation(fields: [pondId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  pondId    String
  tier      String
  message   String
  linkTo    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  pond Pond @relation(fields: [pondId], references: [id])
}

model EnergyDevice {
  id         String    @id @default(cuid())
  mac        String    @unique
  token      String    @unique
  label      String
  pondId     String?
  relayState Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  pond     Pond?           @relation(fields: [pondId], references: [id])
  readings EnergyReading[]
}

model EnergyReading {
  id         String   @id @default(cuid())
  deviceId   String
  timestamp  DateTime
  relayState Boolean
  createdAt  DateTime @default(now())

  device EnergyDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, timestamp])
}
